[
  {
    "platform": "facebook",
    "id": "fb-color-with-ash",
    "label": "Facebook • Color With Ash",
    "credentials": {
      "accessToken": "${FB_COLOR_WITH_ASH_ACCESS_TOKEN}",
      "appId": "${FB_APP_ID}",
      "appSecret": "${FB_APP_SECRET}"
    },
    "metadata": {
      "pageId": "${FB_COLOR_WITH_ASH_PAGE_ID}",
      "pageName": "Color With Ash"
    }
  },
  {
    "platform": "facebook",
    "id": "fb-main-profile",
    "label": "Facebook • Personal Profile",
    "credentials": {
      "accessToken": "${FB_MAIN_PAGE_ACCESS_TOKEN}",
      "appId": "${FB_APP_ID}",
      "appSecret": "${FB_APP_SECRET}"
    },
    "metadata": {
      "pageId": "${FB_MAIN_PAGE_ID}"
    }
  },
  {
    "platform": "substack",
    "id": "substack-main",
    "label": "Substack • Main Publication",
    "credentials": {},
    "metadata": {
      "profileHandle": "${SUBSTACK_PROFILE_HANDLE}",
      "publicationUrl": "${SUBSTACK_PUBLICATION_URL}",
      "newPostUrl": "${SUBSTACK_NEW_POST_URL}",
      "browserOnly": true,
      "browserFirst": true,
      "default": true
    }
  },
  {
    "platform": "x",
    "id": "x-main",
    "label": "X • Main Handle",
    "credentials": {
      "apiKey": "${X_API_KEY}",
      "apiSecret": "${X_API_SECRET}",
      "accessToken": "${X_ACCESS_TOKEN}",
      "accessSecret": "${X_ACCESS_SECRET}"
    }
  },
  {
    "platform": "devto",
    "id": "devto-main",
    "label": "Dev.to • Main Account",
    "credentials": {
      "apiKey": "${DEVTO_API_KEY}"
    }
  },
  {
    "platform": "threads",
    "id": "threads-main",
    "label": "Threads • Main Account",
    "credentials": {
      "accessToken": "${THREADS_ACCESS_TOKEN}",
      "appId": "${THREADS_APP_ID}",
      "appSecret": "${THREADS_APP_SECRET}"
    },
    "metadata": {
      "accountId": "${THREADS_ACCOUNT_ID}"
    }
  },
  {
    "platform": "instagram",
    "id": "ig-main",
    "label": "Instagram • Main Account",
    "credentials": {
      "accessToken": "${INSTAGRAM_ACCESS_TOKEN}",
      "appId": "${INSTAGRAM_APP_ID}",
      "appSecret": "${INSTAGRAM_APP_SECRET}"
    }
  }
]
