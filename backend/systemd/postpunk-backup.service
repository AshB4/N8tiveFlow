[Unit]
Description=PostPunk Backup Snapshot
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/postpunk/backend
EnvironmentFile=/opt/postpunk/.env
ExecStart=/usr/bin/env node scripts/backup/snapshot.mjs
User=postpunk
Group=postpunk
StandardOutput=append:/opt/postpunk/backend/backup.log
StandardError=append:/opt/postpunk/backend/backup.err.log

